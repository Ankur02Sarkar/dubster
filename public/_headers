# Cloudflare static asset headers
# https://developers.cloudflare.com/workers/static-assets/headers

# Immutable Next.js build chunks — content-hashed, safe to cache forever
/_next/static/*
  Cache-Control: public,max-age=31536000,immutable

# OG image — cache for a week, allow stale while revalidating
/og-image.png
  Cache-Control: public,max-age=604800,stale-while-revalidate=86400

# Favicon — cache for a day
/favicon.svg
  Cache-Control: public,max-age=86400

# Security headers applied to every route (/*) including HTML pages
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
